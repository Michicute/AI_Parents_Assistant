# Public URLs
APP_DOMAIN=app.example.com
NEXT_PUBLIC_BACKEND_URL=https://app.example.com
FRONTEND_URL=https://app.example.com
BACKEND_URL=https://app.example.com

# AI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
EMBEDDING_PROVIDER=openai
RAG_AUTO_INGEST_ON_STARTUP=false

# Backend auth/session
APP_ENV=production
APP_SECRET_KEY=replace-with-strong-random-secret
APP_SESSION_EPOCH=

# PostgreSQL container
POSTGRES_DB=c2_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://postgres:replace-with-strong-db-password@db:5432/c2_app

# Internal integration
INTEGRATION_SHARED_SECRET=replace-with-strong-integration-secret
ZALO_LINK_SESSION_TTL_MINUTES=30
ZALO_SESSION_ENCRYPTION_KEY=

# Zalo bot
ZALO_ADAPTER=zca-js
ZALO_ACCOUNT_LABEL=default
ZALO_LANGUAGE=vi
ZALO_BOT_CHAT_URL=https://zalo.me/<bot-or-oa-id>
ZALO_BOT_DISPLAY_NAME=Zalo Bot trung tam
ZALO_LINK_MESSAGE_PREFIX=LINK
ZALO_BOT_ENABLED_BLUE=false
ZALO_BOT_ENABLED_GREEN=false
SCHEDULED_ZALO_WORKER_ENABLED_BLUE=false
SCHEDULED_ZALO_WORKER_ENABLED_GREEN=false
