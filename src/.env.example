# Shared local app environment for docker-compose and monorepo scripts.

OPENAI_API_KEY=
EVAL_JUDGE_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
ANTHROPIC_API_KEY=

DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
AI_PROVIDER=openai
EMBEDDING_PROVIDER=openai
RAG_AUTO_INGEST_ON_STARTUP=true
EXPOSE_AI_EVIDENCE=false
# RAG_DOCUMENTS_DIR=/absolute/path/to/rag_documents
APP_SECRET_KEY=dev-local-secret
APP_ENV=development
APP_SESSION_EPOCH=

ZALO_SERVICE_URL=http://localhost:4001
INTEGRATION_SHARED_SECRET=change-me
ZALO_LINK_SESSION_TTL_MINUTES=30
ZALO_SESSION_ENCRYPTION_KEY=
