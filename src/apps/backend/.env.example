OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
ANTHROPIC_API_KEY=

DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
AI_PROVIDER=openai
EMBEDDING_PROVIDER=openai
RAG_AUTO_INGEST_ON_STARTUP=true
# RAG_DOCUMENTS_DIR=/absolute/path/to/rag_documents
APP_ENV=development

APP_SECRET_KEY=

# Optional. Leave unset in local Docker if you want browser tokens to expire
# whenever the backend container restarts. Set a stable value in multi-instance
# production deployments so all backend replicas accept the same login tokens.
APP_SESSION_EPOCH=

ZALO_SERVICE_URL=http://localhost:4001
INTEGRATION_SHARED_SECRET=change-me
ZALO_LINK_SESSION_TTL_MINUTES=30
ZALO_SESSION_ENCRYPTION_KEY=

