{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["./plugin/ai-log.ts"],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--experimentalPageIdRouting"]
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    }
  }
}
